{
  "name": "ecosphere",
  "tree": {
    "$className": "DataModel",

    "ReplicatedStorage": {
      "$ignoreUnknownInstances": true,
      "GameConfig": {
        "$path": "src/shared/GameConfig.lua"
      },
      "Hello": {
        "$path": "src/shared/Hello.luau"
      },
      "Remotes": {
        "$className": "Folder",
        "StartGameClient": { "$className": "RemoteEvent" },
        "PaintTrail": { "$className": "RemoteEvent" },
        "PowerupActivated": { "$className": "RemoteEvent" },
        "UpdateProgress": { "$className": "RemoteEvent" },
        "SelectClass": { "$className": "RemoteEvent" },
        "GameStateChanged": { "$className": "RemoteEvent" },
        "CoinCollected": { "$className": "RemoteEvent" },
        "QueueUpdate": { "$className": "RemoteEvent" },
        "ReturnToLobby": { "$className": "RemoteEvent" }
      },
      "SphereCharacter": {
        "$className": "Model",
        "HumanoidRootPart": {
          "$className": "Part",
          "$properties": {
            "Shape": "Ball",
            "Size": [2, 2, 2],
            "CanCollide": true,
            "Massless": true,
            "Transparency": 1
          }
        }
      }
    },

    "ServerScriptService": {
      "$ignoreUnknownInstances": true,
      "$path": "src/server"
    },

    "StarterPlayer": {
      "$ignoreUnknownInstances": true,
      "StarterPlayerScripts": {
        "$ignoreUnknownInstances": true,
        "$path": "src/client"
      }
    },

    "Workspace": {
      "$ignoreUnknownInstances": true,
      "$properties": {
        "FilteringEnabled": true
      },
      "Baseplate": {
        "$className": "Part",
        "$properties": {
          "Anchored": true,
          "Color": [
            0.38823,
            0.37254,
            0.38823
          ],
          "Locked": true,
          "Position": [
            0,
            -10,
            0
          ],
          "Size": [
            512,
            20,
            512
          ]
        }
      }
    },
    "Lighting": {
      "$ignoreUnknownInstances": true,
      "$properties": {
        "Ambient": [
          0,
          0,
          0
        ],
        "Brightness": 2,
        "GlobalShadows": true,
        "Outlines": false,
        "Technology": "Voxel"
      }
    },
    "SoundService": {
      "$ignoreUnknownInstances": true,
      "$properties": {
        "RespectFilteringEnabled": true
      }
    }
  }
}